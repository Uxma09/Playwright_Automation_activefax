{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Playwright Tests",
      "program": "${workspaceFolder}/node_modules/playwright/test",
      "args": [
        "test",
        "${file}"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "cwd": "${workspaceFolder}",
      "env": {
        "DEBUG": "pw:api"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug All Playwright Tests",
      "program": "${workspaceFolder}/node_modules/playwright/test",
      "args": [
        "test"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "cwd": "${workspaceFolder}",
      "env": {
        "DEBUG": "pw:api"
      }
    }
  ]
}
